# ==============================================================================
# BioKan — .gitignore
# ==============================================================================

# Données de simulation (trop volumineuses — 700+ MB)
outputs/
*.jld2
*.jld

# Plots et figures générés
plots/
*.png
*.svg
*.pdf
*.eps
# …sauf le rapport de stage, versionné dans report/
!report/rapport_DEUMIER_Constantin.pdf

# Logs SLURM / exécution
logs/
*.log
*.out
*.err

# Librairie locale RateDistortion (dépendance externe, non versionnée ici)
lib/

# Dossier inputs vide
inputs/

# Julia
Manifest.toml
*.ji
*.so
*.dylib
*.dll

# macOS
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# Éditeurs
.vscode/
.idea/
*.swp
*.swo
*~

# Environnements Julia locaux
.julia/

# ==============================================================================
# Scripts de développement / cluster — conservés en local, hors du dépôt public
# ==============================================================================
scripts/
tests/
experimental/

# Scripts de lancement SLURM et de synchronisation cluster
*.sbatch
*.sh
Manifest.cluster.toml

# Restes LaTeX
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
